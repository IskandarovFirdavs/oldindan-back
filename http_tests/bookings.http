@ownerToken = YOUR_OWNER_ACCESS_TOKEN
@managerToken = YOUR_MANAGER_ACCESS_TOKEN
@receptionToken = YOUR_RECEPTION_ACCESS_TOKEN

### =========================
### CONSUMER CREATE BOOKING
### =========================
POST {{baseUrl}}/create/
Authorization: Bearer {{consumerToken}}
Content-Type: application/json

{
  "branch": 1,
  "floor": 1,
  "zone": 1,
  "table": 2,
  "guest_count": 2,
  "children_count": 0,
  "booking_start": "2026-05-3T18:00:00Z",
  "booking_end": "2026-05-3T20:00:00Z",
  "special_request": "Window side"
}

### MY BOOKINGS
GET {{baseUrl}}/my/
Authorization: Bearer {{consumerToken}}

### MY BOOKING DETAIL
GET {{baseUrl}}/my/1/
Authorization: Bearer {{consumerToken}}

### MY BOOKING CANCEL
POST {{baseUrl}}/my/1/cancel/
Authorization: Bearer {{consumerToken}}
Content-Type: application/json

{
  "note": "Plans changed"
}

### =========================
### PARTNER BOOKING LIST
### =========================
GET {{baseUrl}}/partner/?branch_id=1&status=pending
Authorization: Bearer {{ownerToken}}

### PARTNER BOOKING DETAIL
GET {{baseUrl}}/partner/1/
Authorization: Bearer {{ownerToken}}

### PARTNER MANUAL BOOKING CREATE
POST {{baseUrl}}/partner/manual-create/
Authorization: Bearer {{receptionToken}}
Content-Type: application/json

{
  "branch": 1,
  "floor": 1,
  "zone": 1,
  "table": 2,
  "guest_count": 2,
  "children_count": 0,
  "booking_start": "2026-04-10T19:00:00Z",
  "booking_end": "2026-04-10T20:30:00Z",
  "special_request": "Walk-in guest"
}

### PARTNER UPDATE STATUS
POST {{baseUrl}}/partner/1/status/
Authorization: Bearer {{managerToken}}
Content-Type: application/json

{
  "status": "checked_in",
  "note": "Guest arrived"
}

### OCCUPIED TABLES
GET {{baseUrl}}/partner/occupied-tables/?branch_id=1&floor_id=1&booking_start=2026-04-10T18:00:00Z&booking_end=2026-04-10T20:00:00Z
Authorization: Bearer {{receptionToken}}