# OLDINDAN Mobile App Environment Variables

# Backend API Configuration
# This is configurable in the app Settings, but you can set a default here if needed
REACT_APP_API_BASE_URL=http://localhost:8000

# For ngrok testing, use your ngrok URL:
# REACT_APP_API_BASE_URL=https://1234-xxxx-xxxx.ngrok.io

# Note: The app uses AsyncStorage for persistent settings,
# so the API URL set in app Settings will override this.
