@baseUrl = http://127.0.0.1:8000/api/staff
@ownerToken = YOUR_OWNER_ACCESS_TOKEN
@managerToken = YOUR_MANAGER_ACCESS_TOKEN
@superadminToken = YOUR_SUPERADMIN_ACCESS_TOKEN

### =========================
### STAFF LIST (OWNER)
### =========================
# Owner o'z brandidagi barcha stafflarni ko'radi
GET {{baseUrl}}/partner/staff/
Authorization: Bearer {{ownerToken}}

### =========================
### STAFF LIST (MANAGER)
### =========================
# Manager faqat o'z branchidagi stafflarni ko'radi
GET {{baseUrl}}/partner/staff/
Authorization: Bearer {{managerToken}}

### =========================
### STAFF LIST (SUPERADMIN)
### =========================
GET {{baseUrl}}/partner/staff/
Authorization: Bearer {{superadminToken}}

### =========================
### STAFF DETAIL
### =========================
GET {{baseUrl}}/partner/staff/1/
Authorization: Bearer {{ownerToken}}

### =========================
### UPDATE STAFF ROLE OR STATUS (OWNER ONLY)
### =========================
PATCH {{baseUrl}}/partner/staff/1/
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "role": "waiter",
  "is_active": true
}

### =========================
### MY STAFF MEMBERSHIPS (STAFF USER O'ZINI KO'RADI)
### =========================
# Manager, receptionist, waiter, waitress o'zlarining qaysi branchda 
# va qanday rolda ekanligini ko'rishlari mumkin
GET {{baseUrl}}/my-memberships/
Authorization: Bearer {{managerToken}}